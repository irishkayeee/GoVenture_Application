{
  "expo": {
    "name": "GoVenture Travel and Tours",
    "slug": "goventure_app",
    "description": "Book curated, hassle-free tours and travel packages with GoVenture Travel and Tours.",
    "version": "1.0.0",
    "orientation": "portrait",
    "icon": "./assets/images/go_logo.png",
    "scheme": "goventureapp",
    "userInterfaceStyle": "automatic",
    "newArchEnabled": true,
    "primaryColor": "#C46B1A",
    "backgroundColor": "#F8E4D5",
    "ios": {
      "supportsTablet": true,
      "bundleIdentifier": "com.goventure.travelandtours",
      "icon": "./assets/images/go_logo.png"
    },
    "android": {
      "package": "com.goventure.travelandtours",
      "adaptiveIcon": {
        "backgroundColor": "#F8E4D5",
        "foregroundImage": "./assets/images/android-icon-foreground.png",
        "backgroundImage": "./assets/images/android-icon-background.png",
        "monochromeImage": "./assets/images/android-icon-monochrome.png"
      },
      "edgeToEdgeEnabled": true,
      "predictiveBackGestureEnabled": false
    },
    "web": {
      "output": "static",
      "favicon": "./assets/images/favicon.png",
      "bundler": "metro"
    },
    "plugins": [
      "expo-router",
      [
        "expo-splash-screen",
        {
          "image": "./assets/images/splash-icon.png",
          "imageWidth": 200,
          "resizeMode": "contain",
          "backgroundColor": "#F8E4D5",
          "dark": {
            "backgroundColor": "#3B1A0C"
          }
        }
      ],
      "expo-font"
    ],
    "experiments": {
      "typedRoutes": true,
      "reactCompiler": true
    }
  }
}